{
  "manifest_version": 3,
  "name": "GalTools FC26",
  "version": "2.0.0",
  "description": "L'assistant FC26 du peuple. Meta, SBC, Marche, Investissement - connecte FUT.GG en temps reel.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GalTools FC26"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://fut.gg/*",
    "https://www.futbin.com/*",
    "https://api.anthropic.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
